# Environment variables template
# Copy this file to .env and fill in your values

# Not needed - API keys are configured via UI
# MAGNIFIC_API_KEYS=key1,key2,key3

# Not needed - Webhook URL is configured via UI
# WEBHOOK_BASE_URL=https://yourdomain.com

# Not needed - Webhook secret is configured via UI
# MAGNIFIC_WEBHOOK_SECRET=your_webhook_secret_here

# Database (auto-created)
# DATABASE_PATH=data/database.db

# Cache directory (auto-created)
# CACHE_DIR=data/cache

# Log directory (auto-created)
# LOG_DIR=data/logs
